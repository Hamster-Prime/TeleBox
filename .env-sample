# 命令前缀 空格分隔
# TB_PREFIX=. 。
# Sudo 命令前缀 空格分隔
# TB_SUDO_PREFIX=# $
# Telegram API/Session 可由外部 secret manager 注入，避免落盘到 config.json
# TB_API_ID=123456
# TB_API_HASH=0123456789abcdef0123456789abcdef
# TB_SESSION=1A...
# Telegram 连接重试次数
# TB_CONNECTION_RETRIES=5
# Node 22+ localStorage 文件路径
# TB_LOCALSTORAGE_FILE=/home/telebox/.cache/telebox/node-localstorage
# 全局设置命令是否忽略编辑的消息
# TB_CMD_IGNORE_EDITED=false
# 设置哪些插件的监听不忽略编辑的消息 空格分隔
# TB_LISTENER_HANDLE_EDITED=sudo sure
